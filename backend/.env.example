# NextTrack API - Environment Configuration
# Copy this file to .env and update with your values

# DATABASE CONFIGURATION (REQUIRED)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexttrack
DB_USER=postgres
DB_PASSWORD=postgres

# SPOTIFY API CREDENTIALS (OPTIONAL - system works without them)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# API SERVER
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# LOGGING
LOG_LEVEL=INFO
