# NextTrack API - Environment Configuration Template
# Copy this file to .env and fill in your actual values


# SPOTIFY API CREDENTIALS (REQUIRED)

# Get these from: https://developer.spotify.com/dashboard
# 1. Log in to Spotify Developer Dashboard
# 2. Create a new app
# 3. Copy the Client ID and Client Secret

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here



# API SERVER CONFIGURATION (OPTIONAL)

# Host to bind the API server to
# Default: 0.0.0.0 (all network interfaces)
API_HOST=0.0.0.0

# Port to run the API server on
# Default: 8000
API_PORT=8000

# Enable auto-reload on code changes (development only)
# Default: true
API_RELOAD=true



# LOGGING CONFIGURATION (OPTIONAL)

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO



# SETUP INSTRUCTIONS

# 1. Copy this file: cp .env.example .env
# 2. Get Spotify credentials from https://developer.spotify.com/dashboard
# 3. Replace "your_spotify_client_id_here" and "your_spotify_client_secret_here"
# 4. Save the .env file
# 5. Run: python -m app.main
